{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "alloftech.site" }],
      "destination": "https://www.alloftech.site/$1",
      "permanent": true
    },
    {
      "source": "/(.*)\\.html$",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/case-studies",
      "destination": "/case-studies.html"
    },
    {
      "source": "/terms-and-conditions",
      "destination": "/terms-and-conditions.html"
    },
    {
      "source": "/blog/:slug",
      "destination": "/blog/:slug.html"
    },
    {
      "source": "/services/:slug",
      "destination": "/services/:slug.html"
    }
  ]
}
